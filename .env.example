# ---------------------------------------------------------------------------
# DeRush environment variables
# Copy this file to `.env.local` and fill in real values.
# ---------------------------------------------------------------------------

# --- Convex (https://dashboard.convex.dev) ---------------------------------
# This is the public URL the browser uses to talk to your Convex deployment.
# Pre-filled with this project's cloud deployment (little-bison-51). When you
# run `npx convex dev` locally it will confirm / update this value.
NEXT_PUBLIC_CONVEX_URL=https://little-bison-51.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://little-bison-51.convex.site

# --- Clerk (https://dashboard.clerk.com) -----------------------------------
# Clerk application: app_3Fg4SPYDxB6RVBV8fkIYhv2k1TV
# Found under "API Keys" in your Clerk application. `clerk init` writes these
# for you automatically; otherwise copy them from the dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# The Clerk JWT issuer domain (Clerk dashboard → JWT Templates → "convex").
# Used by Convex to validate authenticated requests. Looks like:
#   https://your-app-name.clerk.accounts.dev
# Set the SAME value in the Convex deployment env:
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-app-name.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://your-app-name.clerk.accounts.dev

# Where Clerk should send users for auth. Defaults below match the app routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
